PORT=5005
NODE_ENV=development

# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Meta WhatsApp Cloud API
# Get from: developers.facebook.com → Your App → WhatsApp → API Setup
META_PHONE_ID="your_phone_number_id"
META_ACCESS_TOKEN="EAAxxxxx..."
META_VERIFY_TOKEN="flowdesk-webhook-secret"
# Set to "true" once task_assignment + task_escalation templates are approved by Meta
META_TEMPLATES_APPROVED="false"

# CORS — frontend origin
FRONTEND_URL="http://localhost:5173"

# Cloudinary — media storage for WhatsApp image/doc attachments
# Sign up free at cloudinary.com → Dashboard → copy these 3 values
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
